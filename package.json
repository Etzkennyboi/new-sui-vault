{
  "name": "suisyndicate-root",
  "version": "1.0.0",
  "description": "Root workspace and script runners for SuiSyndicate",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "sdk"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=frontend",
    "backend:dev": "npm run dev --workspace=backend",
    "sdk:build": "npm run build --workspace=sdk",
    "bootstrap": "npm run bootstrap --workspace=backend",
    "agent": "npm run agent --workspace=backend",
    "test:connections": "npm run test:connections --workspace=backend",
    "test:flow": "npm run test:flow --workspace=backend",
    "test:scenarios": "npm run test:scenarios --workspace=backend"
  },
  "dependencies": {
    "@cetusprotocol/cetus-sui-clmm-sdk": "^5.4.0",
    "@mysten/sui": "^2.17.0",
    "dotenv": "^16.4.5",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
